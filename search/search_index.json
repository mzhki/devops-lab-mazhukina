044c \u0443\u0441\u0442\u043e\u0439\u0447\u0438\u0432\u044b\u0439 \u043e\u0431\u0440\u0430\u0437 2\u0413\u0418\u0421 \u043a\u0430\u043a \u0436\u0438\u0432\u043e\u0439 tech-\u043a\u043e\u043c\u043f\u0430\u043d\u0438\u0438 \u0438 \u0441\u0438\u043b\u044c\u043d\u043e\u0433\u043e HR-\u0431\u0440\u0435\u043d\u0434\u0430  \u0432 \u0441\u043e\u0437\u043d\u0430\u043d\u0438\u0438 \u0446\u0435\u043b\u0435\u0432\u043e\u0439 \u0430\u0443\u0434\u0438\u0442\u043e\u0440\u0438\u0438 - \u0447\u0435\u0440\u0435\u0437 \u043f\u0435\u0440\u0435\u043e\u0441\u043c\u044b\u0441\u043b\u0435\u043d\u0438\u0435 SMM-\u0441\u0442\u0440\u0430\u0442\u0435\u0433\u0438\u0438.</p>"},{"location":"projects/#_2","title":"\u2708\ufe0f \u041c\u0430\u0440\u043a\u0435\u0442\u0438\u043d\u0433\u043e\u0432\u0430\u044f \u0441\u0442\u0440\u0430\u0442\u0435\u0433\u0438\u044f \u041e'\u041c\u0435\u0434\u0438\u043a\u0430","text":"<p>\u041f\u043e\u0438\u0441\u043a \u043d\u043e\u0432\u044b\u0445 \u043f\u0443\u0442\u0435\u0439 \u043f\u0440\u043e\u0434\u0432\u0438\u0436\u0435\u043d\u0438\u044f \u043c\u0435\u0434.\u0446\u0435\u043d\u0442\u0440\u0430 \u0432 \u0441\u043f\u0430\u043b\u044c\u043d\u043e\u043c \u0440\u0430\u0439\u043e\u043d\u0435 \u0421\u0430\u043d\u043a\u0442-\u041f\u0435\u0442\u0435\u0440\u0431\u0443\u0440\u0433\u0430.</p>"},{"location":"projects/#_3","title":"\ud83d\udcdd \u0420\u0430\u0431\u043e\u0447\u0438\u0435 \u043f\u0440\u043e\u0435\u043a\u0442\u044b","text":"<p>\u0412 \u0441\u0432\u044f\u0437\u0438 \u0441 \u043a\u043e\u043d\u0444\u0438\u0434\u0435\u043d\u0446\u0438\u0430\u043b\u044c\u043d\u043e\u0441\u0442\u044c\u044e \u043d\u0435 \u043c\u043e\u0433\u0443 \u0440\u0430\u0441\u043a\u0440\u044b\u0442\u044c \u043f\u0440\u043e\u0435\u043a\u0442\u044b, \u043d\u0430\u0434 \u043a\u043e\u0442\u043e\u0440\u044b\u043c\u0438 \u044f \u0440\u0430\u0431\u043e\u0442\u0430\u044e \u0432 \u0441\u0432\u043e\u0435\u0439 \u043a\u043e\u043c\u043f\u0430\u043d\u0438\u0438.</p>"}]}